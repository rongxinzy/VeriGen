{
	"name": "@earendil-works/pi-verigen",
	"version": "0.78.1",
	"description": "VeriGen Verilog analysis orchestration helpers for pi",
	"type": "module",
	"bin": {
		"verigen": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js && node scripts/copy-python-worker.mjs",
		"test": "node --test test/*.test.ts",
		"prepack": "npm run build",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"graphology": "0.26.0",
		"vectra": "0.15.0",
		"zod": "4.4.3"
	},
	"keywords": [
		"ai",
		"verilog",
		"rtl",
		"verification",
		"agent"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi.git",
		"directory": "packages/verigen"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
