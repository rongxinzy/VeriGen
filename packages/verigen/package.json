{
	"name": "verigen",
	"version": "0.79.17",
	"description": "Verilog-specialized coding agent with RTL generation, simulation, tracing, and repair workflows",
	"type": "module",
	"bin": {
		"verigen": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./coding-agent-extension": {
			"types": "./dist/verigen-coding-agent-extension.d.ts",
			"import": "./dist/verigen-coding-agent-extension.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"!dist/native-tools",
		"!dist/native-tools/**",
		"!dist/native-tools-manifest.json",
		"install.ps1",
		"install.sh",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/cli.js && node scripts/copy-python-worker.mjs && shx rm -rf dist/native-tools dist/native-tools-manifest.json",
		"native-tools:install-current": "node scripts/install-native-tools.mjs --install-current",
		"test": "node --test test/*.test.ts",
		"prepack": "npm run build",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "0.79.0",
		"@earendil-works/pi-tui": "0.79.0",
		"graphology": "0.26.0",
		"typebox": "1.1.38",
		"vectra": "0.15.0",
		"zod": "4.4.3"
	},
	"keywords": [
		"ai",
		"verilog",
		"rtl",
		"verification",
		"agent"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rongxinzy/VeriGen.git",
		"directory": "packages/verigen"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
